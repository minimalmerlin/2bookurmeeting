generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL") // Uses Vercel Postgres Connection Pool URL
}

// NextAuth Models required for Google Provider
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  username      String?   @unique
  workingHours  String?   @default("[{\"day\":1,\"start\":\"09:00\",\"end\":\"17:00\"},{\"day\":2,\"start\":\"09:00\",\"end\":\"17:00\"},{\"day\":3,\"start\":\"09:00\",\"end\":\"17:00\"},{\"day\":4,\"start\":\"09:00\",\"end\":\"17:00\"},{\"day\":5,\"start\":\"09:00\",\"end\":\"17:00\"}]") // JSON string storing weekly schedule
  
  accounts      Account[]
  sessions      Session[]
  eventTypes    EventType[]
  bookings      Booking[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Calendly Clone Custom Models
model EventType {
  id          String    @id @default(cuid())
  title       String
  description String?
  duration    Int       // duration in minutes
  slug        String
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookings    Booking[]

  @@unique([userId, slug])
}

model Booking {
  id            String    @id @default(cuid())
  eventTypeId   String
  eventType     EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  
  userId        String    // Quick ref to owner
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  attendeeName  String
  attendeeEmail String
  
  startTime     DateTime
  endTime       DateTime
  googleEventId String?

  createdAt     DateTime  @default(now())
}
