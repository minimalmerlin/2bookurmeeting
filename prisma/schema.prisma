generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL") // Uses Vercel Postgres Connection Pool URL
}

// NextAuth Models required for Google Provider
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  username      String?   @unique
  webhookUrl    String?   // Added for n8n/Zapier automations
  workingHours  String?   @default("{\"0\":{\"enabled\":false,\"slots\":[]},\"1\":{\"enabled\":true,\"slots\":[{\"start\":\"09:00\",\"end\":\"17:00\"}]},\"2\":{\"enabled\":true,\"slots\":[{\"start\":\"09:00\",\"end\":\"17:00\"}]},\"3\":{\"enabled\":true,\"slots\":[{\"start\":\"09:00\",\"end\":\"17:00\"}]},\"4\":{\"enabled\":true,\"slots\":[{\"start\":\"09:00\",\"end\":\"17:00\"}]},\"5\":{\"enabled\":true,\"slots\":[{\"start\":\"09:00\",\"end\":\"17:00\"}]},\"6\":{\"enabled\":false,\"slots\":[]}}")
  
  accounts      Account[]
  sessions      Session[]
  eventTypes    EventType[]
  bookings      Booking[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Calendly Clone Custom Models
model EventType {
  id              String    @id @default(cuid())
  title           String
  description     String?
  duration        Int       // duration in minutes
  slug            String
  customQuestions String?   // JSON string storing an array of custom questions
  pageViews       Int       @default(0)
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookings        Booking[]

  @@unique([userId, slug])
}

model Booking {
  id              String    @id @default(cuid())
  eventTypeId     String
  eventType       EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  
  userId          String    // Quick ref to owner
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  attendeeName    String
  attendeeEmail   String
  customAnswers   String?   // JSON string storing the answers to the custom questions
  
  startTime       DateTime
  endTime         DateTime
  googleEventId   String?

  createdAt       DateTime  @default(now())
}
